import tkinter as tk
from tkinter import filedialog

class SmartLabelTool:
    def __init__(self, root):
        self.root = root
        self.root.title("Smart Label Tool - AI Annotation")
        self.root.geometry("800x600")

        # UI Elements
        self.label = tk.Label(root, text="Upload an image to start labeling", font=("Arial", 14))
        self.label.pack(pady=20)

        self.upload_btn = tk.Button(root, text="Upload Image", command=self.load_image)
        self.upload_btn.pack()

    def load_image(self):
        file_path = filedialog.askopenfilename()
        if file_path:
            print(f"Loaded: {file_path}")
            self.label.config(text=f"Editing: {file_path.split('/')[-1]}")

if __name__ == "__main__":
    root = tk.Tk()
    app = SmartLabelTool(root)
    root.mainloop()
